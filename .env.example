# Local daemon
# Leave blank to use the per-user default shared by the daemon and stdio MCP plugin.
# If overridden, use one absolute path and expose it to every Brain Hub process.
BRAINHUB_DB_PATH=

# Prefer an OS keychain. This explicit key is intended for ephemeral development only.
# Generate 32 random bytes and encode them as URL-safe base64 without sharing it.
BRAINHUB_MASTER_KEY=

# Local clients. Replace this value before listening on a non-loopback interface.
BRAINHUB_API_TOKEN=local-development-only

# Raw content is denied unless both the event opts into content capture and this
# deployment-level switch is enabled. Hidden reasoning and secrets stay forbidden.
BRAINHUB_ALLOW_RAW_CONTENT=false

# Web client
VITE_BRAINHUB_API_URL=http://127.0.0.1:8420
VITE_BRAINHUB_WS_URL=ws://127.0.0.1:8420/ws
