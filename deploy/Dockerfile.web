FROM node:22-alpine AS build
WORKDIR /app
COPY apps/web/package.json apps/web/package-lock.json ./
RUN npm ci
COPY apps/web/ ./
ARG VITE_BRAINHUB_API_URL=http://127.0.0.1:8420
ARG VITE_BRAINHUB_WS_URL=ws://127.0.0.1:8420
ENV VITE_BRAINHUB_API_URL=$VITE_BRAINHUB_API_URL \
    VITE_BRAINHUB_WS_URL=$VITE_BRAINHUB_WS_URL
RUN npm run build

FROM nginxinc/nginx-unprivileged:1.27-alpine
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /packages/core/src/brainhub/web_dist /usr/share/nginx/html
EXPOSE 8080
