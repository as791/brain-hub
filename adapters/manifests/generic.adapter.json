{
  "schema_version": "1",
  "id": "brainhub.generic",
  "display_name": "Generic agent adapter",
  "version": "0.1.0",
  "command": ["brainhub-adapter", "capture", "--agent", "generic"],
  "delivery": {
    "command": ["brainhub-adapter", "watch"],
    "token_env": "BRAINHUB_API_TOKEN",
    "supervision": "foreground"
  },
  "inputs": ["hook", "otlp", "stream", "mcp", "manual", "import"],
  "privacy": {
    "default_content_level": "metadata",
    "reads_transcripts": false,
    "absolute_paths": "hash"
  }
}
