{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brainhub.local/schemas/adapter-manifest.v1.json",
  "title": "Brain Hub adapter manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "display_name", "version", "command", "delivery", "inputs", "privacy"],
  "properties": {
    "schema_version": {"const": "1"},
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9.-]{1,79}$"},
    "display_name": {"type": "string", "minLength": 1, "maxLength": 80},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "command": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "delivery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "token_env", "supervision"],
      "properties": {
        "command": {
          "type": "array",
          "minItems": 2,
          "items": {"type": "string", "minLength": 1}
        },
        "token_env": {"const": "BRAINHUB_API_TOKEN"},
        "supervision": {"const": "foreground"}
      }
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"enum": ["hook", "otlp", "stream", "mcp", "manual", "import"]}
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default_content_level", "reads_transcripts", "absolute_paths"],
      "properties": {
        "default_content_level": {"enum": ["metadata", "summary"]},
        "reads_transcripts": {"const": false},
        "absolute_paths": {"const": "hash"}
      }
    }
  }
}
