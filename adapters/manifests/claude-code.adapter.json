{
  "schema_version": "1",
  "id": "anthropic.claude-code",
  "display_name": "Claude Code",
  "version": "0.1.0",
  "command": ["brainhub-claude-hook"],
  "delivery": {
    "command": ["brainhub-adapter", "watch"],
    "token_env": "BRAINHUB_API_TOKEN",
    "supervision": "foreground"
  },
  "inputs": ["hook", "otlp", "stream", "mcp"],
  "privacy": {
    "default_content_level": "metadata",
    "reads_transcripts": false,
    "absolute_paths": "hash"
  }
}
