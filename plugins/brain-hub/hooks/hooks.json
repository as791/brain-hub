{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$PLUGIN_ROOT/scripts/capture_hook.py\"",
            "commandWindows": "py -3 \"%PLUGIN_ROOT%\\scripts\\capture_hook.py\"",
            "timeout": 5,
            "statusMessage": "Connecting Brain Hub"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$PLUGIN_ROOT/scripts/capture_hook.py\"",
            "commandWindows": "py -3 \"%PLUGIN_ROOT%\\scripts\\capture_hook.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$PLUGIN_ROOT/scripts/capture_hook.py\"",
            "commandWindows": "py -3 \"%PLUGIN_ROOT%\\scripts\\capture_hook.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$PLUGIN_ROOT/scripts/capture_hook.py\"",
            "commandWindows": "py -3 \"%PLUGIN_ROOT%\\scripts\\capture_hook.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$PLUGIN_ROOT/scripts/capture_hook.py\"",
            "commandWindows": "py -3 \"%PLUGIN_ROOT%\\scripts\\capture_hook.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$PLUGIN_ROOT/scripts/capture_hook.py\"",
            "commandWindows": "py -3 \"%PLUGIN_ROOT%\\scripts\\capture_hook.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$PLUGIN_ROOT/scripts/capture_hook.py\"",
            "commandWindows": "py -3 \"%PLUGIN_ROOT%\\scripts\\capture_hook.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$PLUGIN_ROOT/scripts/capture_hook.py\"",
            "commandWindows": "py -3 \"%PLUGIN_ROOT%\\scripts\\capture_hook.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$PLUGIN_ROOT/scripts/capture_hook.py\"",
            "commandWindows": "py -3 \"%PLUGIN_ROOT%\\scripts\\capture_hook.py\"",
            "timeout": 5,
            "statusMessage": "Checkpointing Brain Hub"
          }
        ]
      }
    ]
  }
}
